{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://providers/workflow-plugin-github/github-runner/v1",
  "title": "Workflow GitHub runner provider configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "organizations": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[^/\\s]+/[^/\\s]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "runner_groups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "api_base_url": {
      "type": "string",
      "format": "uri",
      "anyOf": [
        {
          "pattern": "^https://[^\\s/@?#]+(?::[0-9]+)?(?:/[^\\s?#]*)?$"
        },
        {
          "pattern": "^http://(?:localhost|127(?:\\.[0-9]{1,3}){3}|\\[::1\\])(?::[0-9]+)?(?:/[^\\s?#]*)?$"
        }
      ]
    },
    "state_dir": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^\\S+$"
    },
    "provider_token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^\\S+$"
    }
  },
  "required": [
    "organizations",
    "repositories",
    "state_dir",
    "token",
    "provider_token"
  ]
}
